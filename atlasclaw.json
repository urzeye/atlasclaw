{
  "workspace": {
    "path": "./.atlasclaw"
  },
  "providers_root": "../atlasclaw-providers/providers",
  "skills_root": "../atlasclaw-providers/skills",
  "channels_root": "../atlasclaw-providers/channels",
  "model": {
    "primary": "model-1",
    "fallbacks": [],
    "temperature": "${LLM_TEMPERATURE}",
    "selection_strategy": "health",
    "tokens": [
      {
        "id": "model-1",
        "provider": "${TOKEN_1_PROVIDER}",
        "model": "${TOKEN_1_MODEL}",
        "base_url": "${TOKEN_1_BASE_URL}",
        "api_key": "${TOKEN_1_API_KEY}",
        "api_type": "openai",
        "priority": 100,
        "weight": 100
      },
      {
        "id": "model-2",
        "provider": "${TOKEN_2_PROVIDER}",
        "model": "${TOKEN_2_MODEL}",
        "base_url": "${TOKEN_2_BASE_URL}",
        "api_key": "${TOKEN_2_API_KEY}",
        "api_type": "openai",
        "priority": 90,
        "weight": 80
      },
      {
        "id": "model-3",
        "provider": "${TOKEN_3_PROVIDER}",
        "model": "${TOKEN_3_MODEL}",
        "base_url": "${TOKEN_3_BASE_URL}",
        "api_key": "${TOKEN_3_API_KEY}",
        "api_type": "openai",
        "priority": 80,
        "weight": 60
      }
    ]
  },
  "service_providers": {
    "smartcmp": {
      "local": {
        "base_url": "${SMARTCMP_LOCAL_URL}",
        "cookie": "${SMARTCMP_LOCAL_COOKIE}"
      },
      "default": {
        "CMP_URL": "${CMP_URL}",
        "CMP_COOKIE": "${CMP_COOKIE}"
      }
    }
  },
  "auth": {
    "enabled": false,
    "provider": "oidc",
    "cache_ttl_seconds": 300,
    "oidc": {
      "issuer": "${OIDC_ISSUER}",
      "client_id": "${OIDC_CLIENT_ID}",
      "client_secret": "${OIDC_CLIENT_SECRET}",
      "jwks_uri": "${OIDC_ISSUER}/protocol/openid-connect/certs",
      "scopes": ["openid", "profile", "email"],
      "authorization_endpoint": "${OIDC_ISSUER}/protocol/openid-connect/auth",
      "token_endpoint": "${OIDC_ISSUER}/protocol/openid-connect/token",
      "userinfo_endpoint": "${OIDC_ISSUER}/protocol/openid-connect/userinfo",
      "end_session_endpoint": "${OIDC_ISSUER}/protocol/openid-connect/logout",
      "redirect_uri": "${OIDC_REDIRECT_URI}",
      "pkce_enabled": true,
      "pkce_method": "S256"
    }
  },
  "agent_defaults": {
    "max_concurrent": 10
  },
  "webhook": {
    "enabled": false,
    "header_name": "X-UniClaw-SK",
    "skill_sources": [
      {
        "provider": "smartcmp",
        "root": "../UniClaw-Providers/SmartCMP-Provider/skills"
      },
      {
        "provider": "jira",
        "root": "app/atlasclaw/providers/jira/skills"
      }
    ],
    "systems": [
      {
        "system_id": "smartcmp-preapproval",
        "enabled": true,
        "sk_env": "ATLASCLAW_WEBHOOK_SK_SMARTCMP_PREAPPROVAL",
        "default_agent_id": "main",
        "allowed_skills": [
          "smartcmp:preapproval-agent"
        ]
      }
    ]
  }
}
